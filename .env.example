# Production Vercel & MongoDB Atlas Environment Variables Example

# Database (MongoDB Atlas Connection String)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/jpcollege_erp?retryWrites=true&w=majority

# Backend Security & Server Config
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=production
CLIENT_URL=https://your-frontend.vercel.app
PORT=5000

# Frontend API URL
VITE_API_BASE_URL=https://your-backend.vercel.app/api
VITE_API_URL=https://your-backend.vercel.app/api

